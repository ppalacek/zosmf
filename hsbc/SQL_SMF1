SELECT
  STRIP(PRIMAUTH)      AS PRIMAUTH,
  SUM(CLASS1_CPU_NNESTED)      AS CP_CPU,
  SUM(CLASS1_IIP_CPU_NNESTED)  AS ZIIP_CPU,
  SUM(CLASS1_CPU_NNESTED) + SUM(CLASS1_IIP_CPU_NNESTED) AS TOTAL_CPU
FROM D2PD2Q7.DB2PMSACCT_GENERAL
WHERE DATE(INTERVAL_TIME) = '2026-03-04'
  AND STRIP(PRIMAUTH) = 'LHHNB02S'
GROUP BY STRIP(PRIMAUTH);

SELECT
  SUM(CLASS1_CPU)         AS CP_NESTED,
  SUM(CLASS1_CPU_NNESTED) AS CP_NNESTED,
  SUM(CLASS1_IIP_CPU)         AS ZIIP_NESTED,
  SUM(CLASS1_IIP_CPU_NNESTED) AS ZIIP_NNESTED
FROM D2PD2Q7.DB2PMSACCT_GENERAL
WHERE DATE(INTERVAL_TIME) = '2026-03-04'
  AND STRIP(PRIMAUTH) = 'LHHNB02S';

SELECT SUBSYSTEM_ID, STRIP(CONNECT_TYPE) AS CONNECT_TYPE, COUNT(*) AS ROWS
FROM D2PD2Q7.DB2PMSACCT_GENERAL
WHERE DATE(INTERVAL_TIME)='2026-03-04'
  AND STRIP(PRIMAUTH)='LHHNB02S'
GROUP BY SUBSYSTEM_ID, STRIP(CONNECT_TYPE)
ORDER BY ROWS DESC;
