SELECT
  STRIP(PRIMAUTH) AS PRIMAUTH,
  SUM(CLASS1_CPU_NNESTED) AS CP_CPU,
  SUM(CLASS1_IIP_CPU)     AS ZIIP_CPU,
  SUM(CLASS1_CPU_NNESTED) + SUM(CLASS1_IIP_CPU) AS TOTAL_CPU
FROM D2PD2Q7.DB2PMSACCT_GENERAL
WHERE DATE(INTERVAL_TIME) = '2026-03-04'
  AND STRIP(PRIMAUTH) = 'LHHNB02S'
GROUP BY STRIP(PRIMAUTH);

SELECT
  STRIP(PRIMAUTH) AS PRIMAUTH,
  SUM(CLASS1_CPU_TOTAL) AS CLASS1_TOTAL_CPU
FROM D2PD2Q7.DB2PMSACCT_GENERAL
WHERE DATE(INTERVAL_TIME) = '2026-03-04'
  AND STRIP(PRIMAUTH) = 'LHHNB02S'
GROUP BY STRIP(PRIMAUTH);

SELECT
  STRIP(PRIMAUTH) AS PRIMAUTH,
  SUM(CLASS1_CPU_NNESTED) AS CP_NNESTED,
  SUM(CLASS1_IIP_CPU)     AS ZIIP,
  SUM(CLASS1_CPU_TOTAL)   AS CLASS1_TOTAL
FROM D2PD2Q7.DB2PMSACCT_GENERAL
WHERE DATE(INTERVAL_TIME) = '2026-03-04'
  AND STRIP(PRIMAUTH) = 'LHHNB02S'
GROUP BY STRIP(PRIMAUTH);

SELECT COLNAME
FROM SYSIBM.SYSCOLUMNS
WHERE TBNAME = 'DB2PMSACCT_GENERAL'
  AND TBCREATOR = 'D2PD2Q7'
  AND COLNAME LIKE '%CPU%'
ORDER BY COLNAME;
